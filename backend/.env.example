# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# API Gateway (from CloudFormation outputs)
API_GATEWAY_URL=https://xxxxx.execute-api.us-east-1.amazonaws.com

# SQS Configuration
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/gitsight-analytics-dev

# DynamoDB Configuration
DYNAMODB_TABLE=GitSightMetrics-dev

# GitHub Configuration (optional)
GITHUB_TOKEN=your_github_personal_access_token
